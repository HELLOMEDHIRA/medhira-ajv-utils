{
  "compilerOptions": {
    "target": "ES2017",
    "module": "CommonJS",

    "moduleResolution": "bundler",

    "rootDir": "./src",
    "outDir": "./lib",

    "declaration": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["jest", "node"]
  },
  "include": ["src", "src/__tests__"],
  "exclude": ["node_modules"]
}