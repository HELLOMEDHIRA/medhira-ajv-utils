{
  "name": "medhira-ajv-utils",
  "version": "0.0.1",
  "description": "Custom AJV formats and keywords for validation - Powered by MEDHIRA",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "logo": "https://raw.githubusercontent.com/HELLOMEDHIRA/medhira/main/assets/medhira-logo.png",
  "scripts": {
    "test": "jest --config jest.config.js",
    "build": "tsc",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "npx eslint .",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run lint",
    "preversion": "npm run lint",
    "version": "npm run format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HELLOMEDHIRA/medhira-ajv-utils.git"
  },
  "bugs": {
    "url": "https://github.com/HELLOMEDHIRA/medhira-ajv-utils/issues"
  },
  "homepage": "https://github.com/HELLOMEDHIRA/medhira-ajv-utils#readme",
  "keywords": [
    "medhira",
    "ajv",
    "validation",
    "ajv-formats",
    "ajv-keywords",
    "formats",
    "keywords",
    "json-schema"
  ],
  "author": "MEDHIRA <hello.medhira@gmail.com> (https://medhira.readthedocs.io/en/latest/)",
  "license": "Apache-2.0",
  "devDependencies": {
    "@babel/parser": "^7.29.2",
    "@types/jest": "^30.0.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.2.0",
    "tslint": "^6.1.3",
    "tslint-config-prettier": "^1.18.0",
    "typescript": "^6.0.3"
  },
  "files": [
    "lib/**/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "uuid": "^14.0.0"
  },
  "peerDependencies": {
    "ajv-formats": "^3.0.1",
    "ajv-errors": "^3.0.0"
  }
}